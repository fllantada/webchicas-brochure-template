# =============================================================================
# webchicas-brochure-template — .env.example
# Copiar a .env.local y completar. NO committear .env.local (gitignored).
# =============================================================================

# --- Marca (NEXT_PUBLIC_ → expuesto al cliente, OK porque es público) --------
NEXT_PUBLIC_BRAND_NAME="Nombre del Cliente"
# Logo: ruta relativa a public/, ej "/images/logos/cliente.png". Vacío = muestra texto.
NEXT_PUBLIC_BRAND_LOGO_PATH=
NEXT_PUBLIC_BRAND_DESCRIPTION="Descripción corta del negocio"
NEXT_PUBLIC_BRAND_COUNTRY=ES
# Schema.org @type — LocalBusiness, BeautySalon, Restaurant, ProfessionalService...
NEXT_PUBLIC_SCHEMA_TYPE=LocalBusiness
# URL pública del sitio (NO localhost en prod — afecta metadataBase + sitemap)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# --- Logs (BetterStack/Logtail) ----------------------------------------------
# Slug único del cliente para filtrar logs en BetterStack. Sin espacios.
LOGTAIL_SOURCE=cliente-slug
# Agency-level (vienen del .env.local del workspace WebChicas)
LOGTAIL_TOKEN=
LOGTAIL_HOST=https://s2409654.eu-fsn-3.betterstackdata.com

# --- Auth admin (magic link) -------------------------------------------------
# Generar con: openssl rand -hex 32
JWT_SECRET=

# SendGrid agency-level (compartido entre clientes, FROM=noreply@dev-fran.com)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@dev-fran.com

# --- MongoDB (cluster compartido, 1 DB por cliente) --------------------------
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
# Nombre DB: convención "{slug}cms" (ej. "shenacms", "tapascms")
MONGODB_DB_NAME=clientecms

# --- Vercel Blob (1 store por cliente) ---------------------------------------
BLOB_READ_WRITE_TOKEN=

# --- Admin inicial (para seedAdminUser) --------------------------------------
ADMIN_EMAIL=
ADMIN_NAME=
